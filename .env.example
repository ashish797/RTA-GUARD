# RTA-GUARD Environment Configuration
# Copy to .env and edit for your deployment

# Dashboard
RTA_PORT=8080
RTA_SECRET_KEY=change-me-in-production
RTA_AUTH_TOKEN=

# PostgreSQL
POSTGRES_PASSWORD=rta_secret
DATABASE_URL=postgresql://rta:rta_secret@postgres:5432/rtaguard

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# OpenAI (optional, for semantic embeddings)
OPENAI_API_KEY=

# Prometheus Metrics (opt-in, disabled by default)
METRICS_ENABLED=false

# Monitoring (Docker Compose)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=rta-guard-admin
